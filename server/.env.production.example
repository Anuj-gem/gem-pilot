# ─── FastAPI Scoring Engine — Production Environment ─────────────────────────
# Set these on your AWS instance (ECS task definition, EC2 env, etc.)

OPENAI_API_KEY=sk-proj-...
GEM_API_SECRET=same-secret-as-vercel

# CORS — your Vercel production domain
ALLOWED_ORIGINS=https://yourdomain.com

# Optional: override the autoresearch engine directory
# AUTORESEARCH_DIR=/app/autoresearch

# Optional: override model (default is in scoring config)
# GEM_MODEL=gpt-5-nano
